rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isManager() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'manager';
    }

    // --- User Rules ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'location', 'totalHarvested', 'photoURL', 'role']);
    }

    // --- Harvest Rules ---
    match /harvests/{harvestId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.hunterId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.hunterId == request.auth.uid || isManager());
      allow delete: if isSignedIn() && (resource.data.hunterId == request.auth.uid || isManager());
    }

    // --- Market Price Rules ---
    match /marketPrices/{priceId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn(); // Allow for demo/seeding, in production restrict to isManager()
    }
  }
}
